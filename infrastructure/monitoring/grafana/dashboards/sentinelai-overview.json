{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"sentinelai-backend\"}[5m]))",
          "legendFormat": "Total Requests/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"sentinelai-backend\"}[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Error Rate (4xx & 5xx)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"sentinelai-backend\",status=~\"4..\"}[5m])) / sum(rate(http_requests_total{job=\"sentinelai-backend\"}[5m]))",
          "legendFormat": "4xx Rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"sentinelai-backend\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"sentinelai-backend\"}[5m]))",
          "legendFormat": "5xx Rate",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Security Events",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(security_events_total{job=\"sentinelai-backend\",action=\"blocked\"}[5m])) * 60",
          "legendFormat": "Blocked/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(security_events_total{job=\"sentinelai-backend\",action=\"flagged\"}[5m])) * 60",
          "legendFormat": "Flagged/min",
          "refId": "B"
        },
        {
          "expr": "sum(rate(security_events_total{job=\"sentinelai-backend\",action=\"allowed\"}[5m])) * 60",
          "legendFormat": "Allowed/min",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Request Latency (p50, p95, p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"sentinelai-backend\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"sentinelai-backend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"sentinelai-backend\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "id": 5,
      "title": "Active Users",
      "type": "gauge",
      "targets": [
        {
          "expr": "sum(active_user_sessions{job=\"sentinelai-backend\"})",
          "legendFormat": "Active Users",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "id": 6,
      "title": "Model Usage",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum(model_requests_total{job=\"sentinelai-backend\"}) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "title": "CPU Usage by Service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"sentinelai\",container!=\"\"}[5m])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 8,
      "title": "Memory Usage by Service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"sentinelai\",container!=\"\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 9,
      "title": "RAG Pipeline Operations",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(rag_embeddings_total{job=\"sentinelai-backend\"}[5m])) * 60",
          "legendFormat": "Embeddings/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(rag_queries_total{job=\"sentinelai-backend\"}[5m])) * 60",
          "legendFormat": "Queries/min",
          "refId": "B"
        },
        {
          "expr": "sum(rate(rag_documents_processed_total{job=\"sentinelai-backend\"}[5m])) * 60",
          "legendFormat": "Documents/min",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 10,
      "title": "Guardrails Enforcement",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(guardrail_checks_total{job=\"sentinelai-backend\",result=\"pass\"}[5m])) * 60",
          "legendFormat": "Passed/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(guardrail_checks_total{job=\"sentinelai-backend\",result=\"blocked\"}[5m])) * 60",
          "legendFormat": "Blocked/min",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 11,
      "title": "Database Connections",
      "type": "timeseries",
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"sentinelai\"}",
          "legendFormat": "Active Connections",
          "refId": "A"
        },
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "Max Connections",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "id": 12,
      "title": "Model Provider Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_request_duration_seconds_bucket{job=\"sentinelai-backend\"}[5m])) by (le, provider))",
          "legendFormat": "{{provider}} p95",
          "refId": "A"
        }
      ]
    }
  ],
