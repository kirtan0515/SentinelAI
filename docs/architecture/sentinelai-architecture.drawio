          <mxGeometry x="400" y="370" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sec-detect" value="Prompt Injection Detector (40+ patterns)&#xa;Jailbreak Detector (50+ patterns)&#xa;Sensitive Data Detector (PII masking)&#xa;Heuristic Analyzer (entropy, encoding)&#xa;Response Filter (output validation)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="415" y="395" width="225" height="80" as="geometry" />
        </mxCell>
        <mxCell id="sec-score" value="Scoring: allow / flag / mask / block" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=8;fontColor=#ffcccc;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="415" y="478" width="220" height="15" as="geometry" />
