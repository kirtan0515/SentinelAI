        </mxCell>

        <!-- RAG Pipeline -->
        <mxCell id="rag-box" value="RAG Pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1061B0;fontColor=#ffffff;strokeColor=#1061B0;fontSize=11;verticalAlign=top;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="750" y="370" width="350" height="100" as="geometry" />
        </mxCell>
        <mxCell id="rag-steps" value="Upload → Extract (PDF/DOCX/TXT) → Chunk (recursive + overlap)&#xa;→ Embed (Ollama nomic-embed-text, FREE) → Store (pgvector)&#xa;→ Query (cosine similarity) → Context → LLM → Answer + Sources" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=9;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="765" y="400" width="325" height="55" as="geometry" />
        </mxCell>

